# Copy this file to .env and fill in values as needed.
# All settings have safe defaults for local development.

SECRET_KEY=change-me-in-production

# Optimizer constants (defaults match the assignment spec)
MAX_RANGE_MILES=500
MPG=10
ASSUME_FULL_START_TANK=true
ROUTE_BUFFER_DEG=0.07

# User-agent string sent to Nominatim (required by their ToS)
NOMINATIM_USER_AGENT=fuelroute-optimizer/1.0
